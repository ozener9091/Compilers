<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.compilers_laba1.Controller">
    <BorderPane>
        <top>
            <MenuBar>
                <Menu text="Файл">
                    <MenuItem text="Создать"/>
                    <MenuItem text="Открыть"/>
                    <MenuItem text="Сохранить"/>
                    <MenuItem text="Сохранить как"/>
                    <MenuItem text="Выход"/>
                </Menu>
                <Menu text="Правка">
                    <MenuItem text="Отменить"/>
                    <MenuItem text="Вырезать"/>
                    <MenuItem text="Копировать"/>
                    <MenuItem text="Вставить"/>
                    <MenuItem text="Удалить"/>
                    <MenuItem text="Выделить все"/>
                </Menu>
                <Menu text="Справка">
                    <MenuItem text="Руководство пользователя" onAction="#userManualClick"/>
                    <MenuItem text="О программе" onAction="#aboutClick"/>
                </Menu>
            </MenuBar>
        </top>
    </BorderPane>
    <TextArea></TextArea>
    <Label>Тут выводится что-то...</Label>
</VBox>
